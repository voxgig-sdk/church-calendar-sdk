# BasicCalendarFlow

main: kit: flow: BasicCalendarFlow:
{
  entity: "calendar",
  kind: "basic",
  name: "BasicCalendarFlow",
  step: [
    {
      match: {
        locale: "locale01"
      }

      op: "list",
      valid: [
        {
          apply: "ItemExists",
          def: {
            ref: "calendar_ref01"
          }
        }
      ]
    }
  ],
  "key$": "BasicCalendarFlow"
}